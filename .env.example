# Lokal: nach .env.local kopieren (nicht committen).
# Netlify: Site → Environment variables

# Google Maps (serverseitig; Client erhält Key nur über /api/google-maps-key)
GOOGLE_MAPS_API_KEY=

# Neon Postgres — „Pooled“-URL für Serverless/Netlify empfohlen (Dashboard → Connect)
DATABASE_URL=

# Auth.js v5 — https://authjs.dev
# openssl rand -base64 32
AUTH_SECRET=
# Produktion: öffentliche Site-URL (z. B. https://city-trip-planner.netlify.app)
AUTH_URL=http://localhost:3000

# Google OAuth (Web-Client) — Authorized redirect URI:
#   {AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Alternative auf Netlify: Nutzer nur über Netlify Identity (Dashboard), nicht Auth.js —
# würde anderen Code-Pfad erfordern; aktuell: Kundenkonten via Google OAuth + User-Zeilen in Neon.
