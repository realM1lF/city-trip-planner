# Kopieren nach .env.local für lokale Entwicklung.
# Auf Netlify: Site settings → Environment variables → denselben Namen setzen.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- Netlify: falls der Build mit „secret scanning“ abbricht (Key steht im Bundle) ---
# Zusätzliche Environment variable im Netlify-Dashboard (nicht in Git committen):
# Name:  SECRETS_SCAN_SMART_DETECTION_OMIT_VALUES
# Wert:  derselbe String wie dein Maps-Browser-Key (NEXT_PUBLIC_…), ggf. mehrere mit Komma
# Doku:  https://docs.netlify.com/manage/security/secret-scanning/#manage-false-positives
